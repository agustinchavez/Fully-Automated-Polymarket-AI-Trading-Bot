# ─── Polymarket Bot Environment Variables ───────────────────────────
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── API Keys ─────────────────────────────────────────────────────────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Private key for signing (NEVER log this)
POLYMARKET_PRIVATE_KEY=

# Chain ID (137 = Polygon mainnet, 80001 = Mumbai testnet)
POLYMARKET_CHAIN_ID=137

# ── Web Search ───────────────────────────────────────────────────────
# DuckDuckGo — free, no key needed (pip install duckduckgo-search)
# SearXNG — self-hosted, no key, unlimited (see docker-compose.yml)
SEARXNG_URL=http://localhost:8080

# Paid providers (optional, used as fallback)
SERPAPI_KEY=
BING_API_KEY=
TAVILY_API_KEY=

# ── LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# xAI Grok — sign up at console.x.ai, $25 free credits on signup
# Model: grok-4-fast-reasoning (premium tier only)
XAI_API_KEY=

# DeepSeek — sign up at platform.deepseek.com, 5M free tokens on signup
# Model: deepseek-chat (premium tier, auto-excluded from GEOPOLITICS/ELECTION)
DEEPSEEK_API_KEY=

# ── Research Connectors ─────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — free, instant signup
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Congress.gov — free, instant signup
# https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# CourtListener — free token, create account at courtlistener.com
COURTLISTENER_API_KEY=

# CoinGecko — free demo plan, no credit card
# https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# openFDA — free, optional key for higher rate limits
# https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# Reddit OAuth — register free at reddit.com/prefs/apps → 'script' type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# NCBI/PubMed — optional, free key for higher rate limits
# https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/
NCBI_API_KEY=

# The Odds API — 500 free requests/month
# https://the-odds-api.com/
ODDS_API_KEY=

# API-Football — 100 free requests/day
# https://www.api-football.com/
API_FOOTBALL_KEY=

# Open-Meteo, GDELT, SEC EDGAR, arXiv, World Bank, Metaculus, and Wikipedia require no API key

# ── Bot Contact (used in User-Agent headers for SEC EDGAR, Wikipedia) ──
# Set this to your real email before going live — APIs use it for abuse contact
BOT_CONTACT_EMAIL=

# ── Bot Platforms (interactive kill switch + commands) ─────────
# Configure one or more: Telegram, Discord, Slack
# Telegram — talk to @BotFather, get token + chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord — create bot at discord.com/developers, enable Message Content Intent
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Slack — create app at api.slack.com/apps, enable Socket Mode
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# ── Alerts (notifications — separate from interactive bot) ────
# Discord webhook for alerts/daily summaries (no bot needed)
DISCORD_WEBHOOK_URL=

# ── Email Alerts (SMTP) ───────────────────────────────────────
# Gmail: host=smtp.gmail.com, port=587, use App Password (not real password)
# Outlook: host=smtp.office365.com, port=587
# iCloud: host=smtp.mail.me.com, port=587, use App-Specific Password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ── Safety ───────────────────────────────────────────────────────────
# Must be explicitly set to "true" to enable live trading
ENABLE_LIVE_TRADING=false

# ── Dashboard Security ──────────────────────────────────────────────
# Set to protect dashboard with API key authentication
# DASHBOARD_API_KEY=your-secret-key-here

# ── Error Tracking (optional) ───────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Database (optional, for Postgres) ────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/polymarket_bot
